# ==========================================
# 杀戮尖塔2 MCP 配置
# ==========================================
# MCP 服务器的绝对路径
STS2_MCP_PATH=.\STS2MCP\mcp


# 模型名称
LLM_MODEL_ID=qwen3.5-9b

# API密钥
LLM_API_KEY=null

# 服务地址
LLM_BASE_URL=http://127.0.0.1:1234/v1

# 超时时间（可选，默认60秒）
LLM_TIMEOUT=60

# 模型温度，决定随机性 (0.0 到 2.0。打杀戮尖塔需要严谨算血，建议 0.1~0.3)
LLM_TEMPERATURE=0.2

# 最大输出 Token 数量
LLM_MAX_TOKENS=1000